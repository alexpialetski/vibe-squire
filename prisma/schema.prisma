// https://pris.ly/d/prisma-schema

generator client {
  provider       = "prisma-client"
  output         = "../src/generated/prisma"
  moduleFormat   = "cjs"
}

datasource db {
  provider = "sqlite"
}

/// Key-value runtime settings (precedence: env → row → code default). Keys in `setting-keys.ts`.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// GitHub `owner/repo` → Vibe Kanban repository UUID (for `start_workspace`).
model RepoProjectMapping {
  id                 String   @id @default(cuid())
  githubRepo         String   @unique
  vibeKanbanRepoId   String
  label              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

/// Per-scout scheduling / error surface (e.g. `github-pr-reviews`).
model ScoutState {
  scoutId        String    @id
  lastPollAt     DateTime?
  nextPollAt     DateTime?
  lastError      String?
  /// Increments on poll errors; resets on success/skip. Used for exponential backoff (§11).
  failureStreak  Int       @default(0)
  /// Last successful GitHub PR scout run (§3.2 — surface unmapped skips in status).
  lastPollCandidatesCount Int?
  lastPollSkippedUnmapped Int?
  lastPollIssuesCreated   Int?
  updatedAt      DateTime  @updatedAt
}

/// One GitHub PR scout / sync cycle (scheduled or manual) for operator activity UI.
model PollRun {
  id        String    @id @default(cuid())
  startedAt DateTime  @default(now())
  finishedAt DateTime?
  trigger   String
  /// completed | aborted | failed
  phase     String
  /// When aborted: setup_incomplete, gh_*, mcp_probe, etc.
  abortReason   String?
  errorMessage  String?
  candidatesCount       Int?
  issuesCreated           Int?
  skippedUnmapped         Int?
  skippedBot              Int?
  skippedBoardLimit       Int?
  skippedAlreadyTracked   Int?
  skippedLinkedExisting   Int?
  items PollRunItem[]

  @@index([startedAt(sort: Desc)])
}

/// Per-PR outcome within a PollRun.
model PollRunItem {
  id              String   @id @default(cuid())
  runId           String
  run             PollRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  prUrl           String
  githubRepo      String
  prNumber        Int
  prTitle         String
  authorLogin     String?
  /// created | already_tracked | linked_existing | skipped_unmapped | skipped_bot | skipped_board_limit
  decision        String
  detail          String?
  kanbanIssueId   String?

  @@index([runId])
}

/// Tracks Kanban issues created for a GitHub PR (dedupe + reconciliation when PR leaves review queue).
model SyncedPullRequest {
  id                       String   @id @default(cuid())
  githubRepo               String
  prNumber                 Int
  prUrl                    String   @unique
  kanbanIssueId            String
  kanbanProjectId          String
  vibeKanbanWorkspaceId    String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([githubRepo])
  @@index([kanbanProjectId])
}

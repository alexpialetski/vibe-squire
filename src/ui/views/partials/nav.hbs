<aside class="nav-rail">
  <div class="brand">
    <span class="brand-mark">◇</span>
    <span class="brand-text">vibe-squire</span>
  </div>
  <div class="nav-live" aria-live="polite">
    <span class="nav-live-label muted">Status stream</span>
    <span id="nav-sse-state" class="sse sse-connecting">connecting</span>
  </div>
  <nav class="nav">
    {{#unless navMinimal}}
      <a
        href="/ui/dashboard"
        class="nav-link {{#if (eq active 'dashboard')}}active{{/if}}"
      >Dashboard</a>
      <a
        href="/ui/activity"
        class="nav-link {{#if (eq active 'activity')}}active{{/if}}"
      >Activity</a>
    {{/unless}}

    <div class="nav-settings-group">
      <div class="nav-section-heading" id="nav-heading-settings">Settings</div>
      <a
        href="/ui/settings"
        class="nav-link nav-link-nested {{#if (eq active 'general')}}active{{/if}}"
        aria-labelledby="nav-heading-settings"
      >General</a>
      {{#unless navMinimal}}
        {{#each integrationNavEntries}}
          <a
            href="{{href}}"
            class="nav-link nav-link-nested {{#if (eq ../active id)}}active{{/if}}"
            aria-labelledby="nav-heading-settings"
          >{{label}}</a>
        {{/each}}
      {{/unless}}
    </div>
  </nav>
  {{#if navMinimal}}
    <p class="nav-foot muted">Choose integrations under Settings → General to unlock the operator UI.</p>
  {{else}}
    <p class="nav-foot muted">Operator UI · served by the API process</p>
  {{/if}}
</aside>

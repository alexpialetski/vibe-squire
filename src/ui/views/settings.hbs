{{#> layout title="General" active="general" navMinimal=navMinimal integrationNavEntries=integrationNavEntries}}
  <div class="page">
    <header class="page-head">
      <h1>General</h1>
    </header>

    {{#if error}}
      <div class="banner banner-error">{{error}}</div>
    {{/if}}
    {{#if saved}}
      <div class="banner banner-ok">Settings saved. Scheduler refreshed if the interval changed.</div>
    {{/if}}

    <div class="card">
      <h2>Sync adapters</h2>
      <p class="muted">
        PR source and work board are set at <strong>process start</strong> via
        <code>VIBE_SQUIRE_SOURCE_TYPE</code> and <code>VIBE_SQUIRE_DESTINATION_TYPE</code> (defaults: <code>github</code> → <code>vibe_kanban</code>).
        They are not stored in the database. Change env and restart to switch adapters.
      </p>
      <p class="muted"><strong>Resolved for this process:</strong> {{resolvedSourceLabel}} → {{resolvedDestinationLabel}}</p>
    </div>

    <div class="card">
      <h2>Poll schedule</h2>
      <p class="muted">
        Values shown are effective (env overrides database where configured). Manual &ldquo;Sync now&rdquo; is not limited by the interval.
      </p>
      <form method="post" action="/ui/settings" class="form-stack">
        <fieldset class="fieldset-plain">
          <legend class="field-label">Automatic polling</legend>
          <p class="muted" style="margin: 0 0 0.75rem 0">
            When off, the scheduled timer does not run. Env: <code>VIBE_SQUIRE_SCHEDULED_SYNC_ENABLED</code>. Setting key: <code>scheduled_sync_enabled</code>
          </p>
          <label class="check-row">
            <input
              type="radio"
              name="scheduled_sync_enabled"
              value="true"
              {{#if scheduledSyncEnabled}}checked{{/if}}
            />
            <span>On — run sync on the interval below</span>
          </label>
          <label class="check-row">
            <input
              type="radio"
              name="scheduled_sync_enabled"
              value="false"
              {{#unless scheduledSyncEnabled}}checked{{/unless}}
            />
            <span>Off — timer disabled only</span>
          </label>
        </fieldset>
        <fieldset class="fieldset-plain" style="margin-top: 1rem">
          <legend class="field-label">Kanban issue creation</legend>
          <p class="muted" style="margin: 0 0 0.75rem 0">
            When off, matching PRs stay in triage until you create an issue from the operator UI. Env: <code>VIBE_SQUIRE_AUTO_CREATE_ISSUES</code>. Setting key: <code>auto_create_issues</code>
          </p>
          <label class="check-row">
            <input
              type="radio"
              name="auto_create_issues"
              value="true"
              {{#if autoCreateIssues}}checked{{/if}}
            />
            <span>On — create board issues during sync when caps allow</span>
          </label>
          <label class="check-row">
            <input
              type="radio"
              name="auto_create_issues"
              value="false"
              {{#unless autoCreateIssues}}checked{{/unless}}
            />
            <span>Off — triage only (no automatic issue creation)</span>
          </label>
        </fieldset>
        <div class="form-grid" style="margin-top: 1rem">
          {{#each fields}}
            <label class="field">
              <span class="field-label">{{label}}</span>
              <span class="field-key muted">{{key}}</span>
              <input name="{{key}}" class="input" type="text" value="{{value}}" />
            </label>
          {{/each}}
        </div>
        <div class="actions-row">
          <button type="submit" class="btn primary">Save settings</button>
        </div>
      </form>
    </div>
  </div>
{{/layout}}

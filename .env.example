# Copy to `.env` for local development. `dotenv` loads this before `parseAppEnv` (see `src/config/env-schema.ts`).
#
# Variable references like `${OTHER_VAR}` are NOT expanded (plain dotenv only). Use real values per line.
#
# All vibe-squire configuration uses the `VIBE_SQUIRE_` prefix (see `src/config/env-schema.ts`).
#
# If `VIBE_SQUIRE_DATABASE_URL` is unset, the app derives a path from `VIBE_SQUIRE_DATABASE_PATH`,
# then `VIBE_SQUIRE_DATA_DIR`, then OS defaults (`ensureDatabaseUrlFromEnv` in `src/database/resolve-database-url.ts`).

VIBE_SQUIRE_DATABASE_URL="file:./dev.db"
# VIBE_SQUIRE_HOST=127.0.0.1
# VIBE_SQUIRE_PORT=3000
# VIBE_SQUIRE_DATA_DIR=
# VIBE_SQUIRE_SOURCE_TYPE=github
# VIBE_SQUIRE_DESTINATION_TYPE=vibe_kanban
# VIBE_SQUIRE_SCHEDULED_SYNC_ENABLED=true
# VIBE_SQUIRE_AUTO_CREATE_ISSUES=true   # omit/false = triage (promote PRs in UI); true = create board issues during sync
# VIBE_SQUIRE_POLL_INTERVAL_MINUTES=5
# VIBE_SQUIRE_JITTER_MAX_SECONDS=30
# VIBE_SQUIRE_RUN_NOW_COOLDOWN_SECONDS=60
# VIBE_SQUIRE_LOG_LEVEL=info   # fatal | error | warn | info | debug | trace | silent
# VIBE_SQUIRE_LOG_FILE_PATH=logs/app.log   # omit for console-only; set to enable JSON file logging too
# VIBE_SQUIRE_OPENAPI_ENABLED=true

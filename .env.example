# Copy to `.env` for local development. `ConfigModule` loads this at bootstrap.
#
# If DATABASE_URL is unset, see §5.7: SQLITE_DATABASE_PATH / DATABASE_PATH, VIBE_SQUIRE_DATA_DIR, or OS defaults
# (`ensureDatabaseUrlFromEnv` in `src/database/resolve-database-url.ts`).

DATABASE_URL="file:./dev.db"

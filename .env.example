# Copy to `.env` for local development. `dotenv` loads this before `parseAppEnv` (see `src/config/env-schema.ts`).
#
# Variable references like `${OTHER_VAR}` are NOT expanded (plain dotenv only). Use real values per line.
#
# If DATABASE_URL is unset, see §5.7: DATABASE_PATH, VIBE_SQUIRE_DATA_DIR, or OS defaults
# (`ensureDatabaseUrlFromEnv` in `src/database/resolve-database-url.ts`).

DATABASE_URL="file:./dev.db"
# HOST=127.0.0.1
# PORT=3000
# VIBE_SQUIRE_DATA_DIR=
# SOURCE_TYPE=github
# DESTINATION_TYPE=vibe_kanban
# SCHEDULED_SYNC_ENABLED=true
# LOG_LEVEL=info   # fatal | error | warn | info | debug | trace | silent
# LOG_FILE_PATH=logs/app.log   # omit for console-only; set to enable JSON file logging too
# OPENAPI_ENABLED=true
